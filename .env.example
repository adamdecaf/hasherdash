# Prefer a config file (see hasherdash.example.yaml):
# CONFIG_FILE=./hasherdash.yaml
#   or: hasherdash -config ./hasherdash.yaml

HTTP_ADDR=:8080
POLL_INTERVAL=30s
RESCAN_INTERVAL=30m
MINER_TTL=168h
HISTORY_RETENTION=168h
# HISTORY_POINTS is optional (auto-sized from HISTORY_RETENTION / POLL_INTERVAL; memory mode only)
# SQLite metric history (default hasherdash.db). Set to off for in-memory only.
# Docker Compose mounts ./data → /app/data and uses:
# SQLITE_PATH=/app/data/hasherdash.db
SQLITE_PATH=hasherdash.db

# Discovery targets (any combination)
# MINER_IPS=192.168.1.10,192.168.1.11
# MINER_SUBNET=192.168.1.0/24
# MINER_SUBNETS=192.168.1.0/24,10.0.0.0/24
# MINER_RANGES=192.168.1.1-50
